DATABASE_URL="postgresql://postgres:changeme@db:5432/wealth_manager"
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_USER="admin"
ADMIN_PASSWORD="changeme"
DB_PASSWORD="changeme"

# Auto-topup configuration (cuando Revolut < threshold, transfiere desde Caixa)
TOPUP_SOURCE_BANK="Caixa"
TOPUP_TARGET_BANK="Revolut"
TOPUP_THRESHOLD=100
TOPUP_AMOUNT=200

# API Token para acceso programático (ej: OpenClaw)
# Generar con: openssl rand -hex 32
API_TOKEN=""
