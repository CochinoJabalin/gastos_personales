generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bank {
  id            String         @id @default(uuid())
  bank_name     String
  account_label String
  iban          String?
  balance       Float          @default(0)
  created_at    DateTime       @default(now())
  accounts      Account[]
  transactions  Transaction[]
  mappingRules  MappingRule[]
}

model Account {
  id                String         @id @default(uuid())
  bank_id           String
  bank              Bank           @relation(fields: [bank_id], references: [id])
  account_label     String
  iban              String?
  balance           Float          @default(0)
  is_default        Boolean        @default(false)
  interest_rate     Float          @default(0)
  interest_period   String         @default("none")
  last_interest_date DateTime?
  created_at        DateTime       @default(now())
  transactions      Transaction[]
  crowdlending_investments CrowdlendingInvestment[]
  holdings          InvestmentHolding[]
  transfersFrom     Transfer[]     @relation("TransfersFrom")
  transfersTo       Transfer[]     @relation("TransfersTo")
}

model Originator {
  id         String   @id @default(uuid())
  name       String   @unique
  created_at DateTime @default(now())
}

model CrowdlendingInvestment {
  id                  String        @id @default(uuid())
  account_id          String?
  account             Account?      @relation(fields: [account_id], references: [id])
  fecha_inicio        DateTime
  fecha_fin           DateTime?
  descripcion         String
  meses_iniciales     Int
  meses_extension     Int?
  cantidad            Float
  porcentaje_beneficio Float
  roi                 Float?
  beneficios_brutos   Float?
  impuestos           Float?
  beneficios_netos    Float?
  originador          String
  tipo_shared         Boolean       @default(false)
  status              String        @default("ACTIVE")
  created_at          DateTime      @default(now())
  payments            CrowdlendingPayment[]
}

model CrowdlendingPayment {
  id                      String                  @id @default(uuid())
  investment_id           String
  investment              CrowdlendingInvestment  @relation(fields: [investment_id], references: [id])
  fecha                   DateTime
  importe                 Float
  intereses               Float
  capital                 Float
  created_transaction_id  String?
  comentarios             String?
  created_at              DateTime                @default(now())
}

model Transaction {
  id                        String    @id @default(uuid())
  timestamp                 DateTime  @default(now())
  concept                   String
  amount                    Float
  bank_id                   String
  bank                      Bank      @relation(fields: [bank_id], references: [id])
  account_id                String?
  account                   Account?  @relation(fields: [account_id], references: [id])
  group                     String
  type                      String
  is_recurring              Boolean   @default(false)
  recurring_period          String?
  comentarios               String?
  investment_transaction_id String?
  crowdlending_investment_id String?
  transfer_id               String?
}

model Transfer {
  id              String    @id @default(uuid())

  from_account_id String
  from_account    Account   @relation("TransfersFrom", fields: [from_account_id], references: [id])
  to_account_id   String
  to_account      Account   @relation("TransfersTo", fields: [to_account_id], references: [id])

  amount          Float
  concept         String
  timestamp       DateTime  @default(now())
  status          String    @default("pending") // pending | completed | cancelled

  is_scheduled    Boolean   @default(false)
  frequency       String?   // mensual | anual
  next_run        DateTime?
  end_date        DateTime?
  last_run        DateTime?
  enabled         Boolean   @default(true)

  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  executions      TransferExecution[]
}

model TransferExecution {
  id                    String    @id @default(uuid())
  transfer_id           String
  transfer              Transfer  @relation(fields: [transfer_id], references: [id], onDelete: Cascade)
  
  executed_at           DateTime  @default(now())
  scheduled_for         DateTime? // Date when this execution is scheduled (null for completed executions)
  amount                Float     // Amount actually transferred
  
  from_balance_before   Float     // Source account balance before transfer
  from_balance_after    Float     // Source account balance after transfer
  to_balance_before     Float     // Destination account balance before transfer
  to_balance_after      Float     // Destination account balance after transfer
  
  status                String    @default("completed") // completed | failed | scheduled
  error_message         String?   // If failed, store error message
}

model InvestmentInstrument {
  id                String   @id @default(uuid())
  ticker            String?  @unique  // Optional but unique if present (e.g., "NYSE:KOS", "BME:IDR")
  isin              String?  @unique  // Optional but unique if present (e.g., "US5006881065")
  name              String
  type              String            // STOCK, ETF, ETC, FUND, RIGHT
  currency          String   @default("EUR")
  current_price     Float?
  exchange_rate_to_eur Float? @default(1)
  price_updated_at  DateTime?
  sector            String?
  created_at        DateTime @default(now())
  holdings          InvestmentHolding[]
  transactions      InvestmentTransaction[]
  lots              InvestmentLot[]
}

model InvestmentHolding {
  id                   String   @id @default(uuid())
  instrument_id        String
  instrument           InvestmentInstrument @relation(fields: [instrument_id], references: [id])
  account_id           String?
  account              Account? @relation(fields: [account_id], references: [id])
  total_cantidad       Float    @default(0)
  total_invertido_original Float @default(0)
  total_invertido_eur  Float    @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now())
  transactions         InvestmentTransaction[]
  lots                 InvestmentLot[]
}

model InvestmentLot {
  id                String   @id @default(uuid())
  holding_id        String?
  holding           InvestmentHolding? @relation(fields: [holding_id], references: [id])
  instrument_id     String
  instrument        InvestmentInstrument @relation(fields: [instrument_id], references: [id])
  cantidad_original Float
  cantidad_restante Float
  precio_unitario   Float
  total_original    Float
  total_eur         Float
  fecha_compra      DateTime
  divisa            String
  exchange_rate_compra Float
  created_at        DateTime @default(now())
}

model InvestmentTransaction {
  id                    String   @id @default(uuid())
  instrument_id         String
  instrument            InvestmentInstrument @relation(fields: [instrument_id], references: [id])
  holding_id            String?
  holding               InvestmentHolding? @relation(fields: [holding_id], references: [id])
  type                  String
  cantidad              Float
  precio_unitario       Float
  importe_total         Float
  importe_eur           Float
  divisa                String
  exchange_rate         Float
  date                  DateTime
  is_recurring          Boolean  @default(false)
  recurring_period      String?
  dividend_reinvested   Boolean  @default(false)
  plusvalia_realizada_orig Float?
  plusvalia_realizada_eur  Float?
  comentarios           String?
  created_transaction_id String?
  created_at            DateTime @default(now())
  
  // Campos para dividendos (IRPF)
  importe_bruto_orig    Float?   // Bruto en divisa original
  importe_bruto_eur     Float?   // Bruto convertido a EUR
  retencion_origen_pct  Float?   // % retención país origen
  retencion_origen_eur  Float?   // Retención origen en EUR
  retencion_esp_pct     Float?   // % retención España (19%)
  retencion_esp_eur     Float?   // Retención España en EUR
  dividendo_por_titulo  Float?   // Dividendo por acción
}

model MappingRule {
  id              String @id @default(uuid())
  pattern         String
  default_bank_id String?
  default_bank    Bank?   @relation(fields: [default_bank_id], references: [id])
  default_group   String
  default_type    String
}

model BackupSchedule {
  id          String    @id @default(uuid())
  name        String
  frequency   String    // "daily" | "weekly" | "monthly"
  dayOfWeek   Int?      // 0-6, only for weekly
  dayOfMonth  Int?      // 1-31, only for monthly
  time        String    // "HH:mm" 24h format
  enabled     Boolean   @default(true)
  path        String?   // overrides global backup path
  lastRun     DateTime?
  nextRun     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  logs        BackupLog[]
}

model BackupLog {
  id          String   @id @default(uuid())
  scheduleId  String?
  schedule    BackupSchedule? @relation(fields: [scheduleId], references: [id])
  filename    String
  filepath    String
  size        Int
  stats       String   // JSON string
  createdAt   DateTime @default(now())
}

model AutoTopupConfig {
  id                 String   @id @default("default")
  sourceBankName     String   @default("Caixa")
  targetBankName     String   @default("Revolut")
  threshold          Decimal  @default(100)
  amount             Decimal  @default(200)
  checkIntervalHours Int      @default(3)
  enabled            Boolean  @default(true)
  lastCheck          DateTime?
  updatedAt          DateTime @updatedAt
}

model RedondeoConfig {
  id                String    @id @default(uuid())
  enabled           Boolean   @default(false)
  target_account_id String
  multiplier        Int       @default(5)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("RedondeoConfig")
}

model AppConfig {
  id                          String  @id @default("default")
  backupPath                  String  @default("/backups")
  investmentTargetAllocation  String  @default("{}")
  budgetCategoryConfig        String  @default("{}")
  updatedAt                   DateTime @updatedAt
}
